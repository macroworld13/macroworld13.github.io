    <title>C++ 笔记</title>
    <link href="/2020/01/01/C-%E7%AC%94%E8%AE%B0/"/>
    <url>/2020/01/01/C-%E7%AC%94%E8%AE%B0/</url>
    
    <content type="html"><![CDATA[<h1 id="程序基本架构"><a href="#程序基本架构" class="headerlink" title="程序基本架构"></a>程序基本架构</h1><figure class="highlight cpp"><table><tr><td class="gutter"><pre><span class="line">1</span><br><span class="line">2</span><br><span class="line">3</span><br><span class="line">4</span><br><span class="line">5</span><br><span class="line">6</span><br></pre></td><td class="code"><pre><code class="hljs cpp"><span class="hljs-meta">#<span class="hljs-keyword">include</span> <span class="hljs-string">&lt;bits/stdc++.h&gt;</span></span><br><span class="hljs-keyword">using</span> <span class="hljs-keyword">namespace</span> std;<br><span class="hljs-function"><span class="hljs-type">int</span> <span class="hljs-title">main</span><span class="hljs-params">()</span></span>&#123;<br><br><span class="hljs-keyword">return</span> <span class="hljs-number">0</span>;<br>&#125;<br></code></pre></td></tr></table></figure><h1 id="一维数组定义与输入"><a href="#一维数组定义与输入" class="headerlink" title="一维数组定义与输入"></a>一维数组定义与输入</h1><figure class="highlight excel"><table><tr><td class="gutter"><pre><span class="line">1</span><br><span class="line">2</span><br><span class="line">3</span><br><span class="line">4</span><br><span class="line">5</span><br><span class="line">6</span><br></pre></td><td class="code"><pre><code class="hljs excel"><span class="hljs-built_in">int</span> <span class="hljs-built_in">n</span>;<br>cin &gt;&gt; <span class="hljs-built_in">n</span>;<br><span class="hljs-built_in">int</span> a[<span class="hljs-built_in">n</span>];<br>for(<span class="hljs-built_in">int</span> i = <span class="hljs-number">0</span>;i&lt;<span class="hljs-built_in">n</span>;i++)&#123;<br>cin &gt;&gt; a[i];<br>&#125;<br></code></pre></td></tr></table></figure><h1 id="二维数组定义与输入"><a href="#二维数组定义与输入" class="headerlink" title="二维数组定义与输入"></a>二维数组定义与输入</h1><figure class="highlight scss"><table><tr><td class="gutter"><pre><span class="line">1</span><br><span class="line">2</span><br><span class="line">3</span><br><span class="line">4</span><br><span class="line">5</span><br><span class="line">6</span><br><span class="line">7</span><br><span class="line">8</span><br></pre></td><td class="code"><pre><code class="hljs scss">int n,<span class="hljs-attribute">x</span>;<br>cin &gt;&gt; n &gt;&gt; <span class="hljs-attribute">x</span>;<br>int <span class="hljs-selector-tag">a</span><span class="hljs-selector-attr">[n]</span><span class="hljs-selector-attr">[x]</span>;<br><span class="hljs-built_in">for</span>(int i = <span class="hljs-number">0</span>;i&lt;n;i++)&#123;<br><span class="hljs-built_in">for</span>(int j = <span class="hljs-number">0</span>;j&lt;x;j++)&#123;<br>cin &gt;&gt; <span class="hljs-selector-tag">a</span><span class="hljs-selector-attr">[i]</span><span class="hljs-selector-attr">[j]</span>;<br>&#125;<br>&#125;<br></code></pre></td></tr></table></figure><h1 id="判断质数"><a href="#判断质数" class="headerlink" title="判断质数"></a>判断质数</h1><figure class="highlight cpp"><table><tr><td class="gutter"><pre><span class="line">1</span><br><span class="line">2</span><br><span class="line">3</span><br><span class="line">4</span><br><span class="line">5</span><br><span class="line">6</span><br></pre></td><td class="code"><pre><code class="hljs cpp"><span class="hljs-function"><span class="hljs-type">bool</span> <span class="hljs-title">IsPrime</span><span class="hljs-params">(<span class="hljs-type">int</span> n)</span></span><br><span class="hljs-function"></span>&#123;<br>    <span class="hljs-keyword">if</span>(n &lt;= <span class="hljs-number">1</span>)<span class="hljs-keyword">return</span> <span class="hljs-literal">false</span>;<br>    <span class="hljs-keyword">for</span> (<span class="hljs-type">int</span> i = <span class="hljs-number">2</span>; i &lt; n; i++)<span class="hljs-keyword">if</span> ((n % i) == <span class="hljs-number">0</span>)<span class="hljs-keyword">return</span> <span class="hljs-literal">false</span>;<br>    <span class="hljs-keyword">return</span> <span class="hljs-literal">true</span>;<br>&#125;<br></code></pre></td></tr></table></figure><h1 id="回文数转化"><a href="#回文数转化" class="headerlink" title="回文数转化"></a>回文数转化</h1><figure class="highlight dart"><table><tr><td class="gutter"><pre><span class="line">1</span><br><span class="line">2</span><br><span class="line">3</span><br><span class="line">4</span><br><span class="line">5</span><br><span class="line">6</span><br><span class="line">7</span><br><span class="line">8</span><br><span class="line">9</span><br></pre></td><td class="code"><pre><code class="hljs dart"><span class="hljs-built_in">int</span> huiwen(<span class="hljs-built_in">int</span> <span class="hljs-built_in">num</span>)<br>&#123;<br><span class="hljs-built_in">int</span> g = <span class="hljs-number">0</span>;<br><span class="hljs-keyword">while</span>(<span class="hljs-built_in">num</span>&gt;<span class="hljs-number">0</span>)&#123;<br>g=g*<span class="hljs-number">10</span>+<span class="hljs-built_in">num</span>%<span class="hljs-number">10</span>;<br><span class="hljs-built_in">num</span>/=<span class="hljs-number">10</span>;<br>&#125;<br><span class="hljs-keyword">return</span> g;<br>&#125;<br></code></pre></td></tr></table></figure><h1 id="插入数组元素，并按正序排序"><a href="#插入数组元素，并按正序排序" class="headerlink" title="插入数组元素，并按正序排序"></a>插入数组元素，并按正序排序</h1><figure class="highlight cpp"><table><tr><td class="gutter"><pre><span class="line">1</span><br><span class="line">2</span><br><span class="line">3</span><br><span class="line">4</span><br><span class="line">5</span><br><span class="line">6</span><br><span class="line">7</span><br><span class="line">8</span><br><span class="line">9</span><br><span class="line">10</span><br><span class="line">11</span><br><span class="line">12</span><br><span class="line">13</span><br><span class="line">14</span><br><span class="line">15</span><br><span class="line">16</span><br><span class="line">17</span><br></pre></td><td class="code"><pre><code class="hljs cpp"><span class="hljs-meta">#<span class="hljs-keyword">include</span> <span class="hljs-string">&lt;iostream&gt;</span></span><br><span class="hljs-meta">#<span class="hljs-keyword">include</span><span class="hljs-string">&lt;algorithm&gt;</span></span><br><span class="hljs-keyword">using</span> <span class="hljs-keyword">namespace</span> std;<br><span class="hljs-function"><span class="hljs-type">int</span> <span class="hljs-title">main</span><span class="hljs-params">()</span></span>&#123;<br><span class="hljs-type">int</span> n,m,temp;<br>cin &gt;&gt; n &gt;&gt;m;<br><span class="hljs-type">int</span> a[<span class="hljs-number">1000</span>];<br><span class="hljs-keyword">for</span>(<span class="hljs-type">int</span> i = <span class="hljs-number">0</span>;i&lt;m;i++)&#123;<br>cin &gt;&gt; a[i];<br>&#125;<br>a[m++]=n;<br><span class="hljs-built_in">sort</span>(a,a+m,<span class="hljs-built_in">less</span>&lt;<span class="hljs-type">int</span>&gt;());<br><span class="hljs-keyword">for</span>(<span class="hljs-type">int</span> i = <span class="hljs-number">0</span>;i&lt;m;i++)&#123;<br>cout &lt;&lt; a[i]&lt;&lt;<span class="hljs-string">&quot; &quot;</span>;<br>&#125;<br><span class="hljs-keyword">return</span> <span class="hljs-number">0</span>;<br>&#125;<br></code></pre></td></tr></table></figure><h1 id="删除数组元素"><a href="#删除数组元素" class="headerlink" title="删除数组元素"></a>删除数组元素</h1><figure class="highlight cpp"><table><tr><td class="gutter"><pre><span class="line">1</span><br><span class="line">2</span><br><span class="line">3</span><br><span class="line">4</span><br><span class="line">5</span><br><span class="line">6</span><br><span class="line">7</span><br><span class="line">8</span><br><span class="line">9</span><br><span class="line">10</span><br><span class="line">11</span><br><span class="line">12</span><br><span class="line">13</span><br><span class="line">14</span><br><span class="line">15</span><br><span class="line">16</span><br><span class="line">17</span><br><span class="line">18</span><br></pre></td><td class="code"><pre><code class="hljs cpp"><span class="hljs-meta">#<span class="hljs-keyword">include</span> <span class="hljs-string">&lt;iostream&gt;</span></span><br><span class="hljs-keyword">using</span> <span class="hljs-keyword">namespace</span> std;<br><span class="hljs-function"><span class="hljs-type">int</span> <span class="hljs-title">main</span><span class="hljs-params">()</span></span>&#123;<br><span class="hljs-type">int</span> n,x,temp;<br>cin &gt;&gt; n;<br><span class="hljs-type">int</span> a[n];<br><span class="hljs-keyword">for</span>(<span class="hljs-type">int</span> i = <span class="hljs-number">0</span> ; i&lt;n;i++)&#123;<br>cin &gt;&gt; a[i];<br>&#125;<br>cin &gt;&gt; x;<br>a[x<span class="hljs-number">-1</span>]=<span class="hljs-number">0</span>;<br><span class="hljs-keyword">for</span>(<span class="hljs-type">int</span> i = <span class="hljs-number">0</span>;i&lt;n;i++)&#123;<br><span class="hljs-keyword">if</span>(a[i] != <span class="hljs-number">0</span>)&#123;<br>cout &lt;&lt; a[i]&lt;&lt;<span class="hljs-string">&quot; &quot;</span>;<br>&#125;<br>&#125;<br><span class="hljs-keyword">return</span> <span class="hljs-number">0</span>;<br>&#125;<br></code></pre></td></tr></table></figure><h1 id="求一个数各个数位之和"><a href="#求一个数各个数位之和" class="headerlink" title="求一个数各个数位之和"></a>求一个数各个数位之和</h1><figure class="highlight dart"><table><tr><td class="gutter"><pre><span class="line">1</span><br><span class="line">2</span><br><span class="line">3</span><br><span class="line">4</span><br><span class="line">5</span><br><span class="line">6</span><br><span class="line">7</span><br><span class="line">8</span><br></pre></td><td class="code"><pre><code class="hljs dart"><span class="hljs-built_in">int</span> digitSum(<span class="hljs-built_in">int</span> <span class="hljs-built_in">num</span>) &#123;<br>    <span class="hljs-built_in">int</span> sum = <span class="hljs-number">0</span>;<br>    <span class="hljs-keyword">while</span> (<span class="hljs-built_in">num</span> &gt; <span class="hljs-number">0</span>) &#123;<br>        sum += <span class="hljs-built_in">num</span> % <span class="hljs-number">10</span>;<br>        <span class="hljs-built_in">num</span> /= <span class="hljs-number">10</span>;<br>    &#125;<br>    <span class="hljs-keyword">return</span> sum;<br>&#125;<br></code></pre></td></tr></table></figure><h1 id="十进制数转二进制数"><a href="#十进制数转二进制数" class="headerlink" title="十进制数转二进制数"></a>十进制数转二进制数</h1><figure class="highlight arduino"><table><tr><td class="gutter"><pre><span class="line">1</span><br><span class="line">2</span><br><span class="line">3</span><br><span class="line">4</span><br><span class="line">5</span><br><span class="line">6</span><br><span class="line">7</span><br><span class="line">8</span><br><span class="line">9</span><br></pre></td><td class="code"><pre><code class="hljs arduino"><span class="hljs-function"><span class="hljs-type">int</span> <span class="hljs-title">to2</span><span class="hljs-params">(<span class="hljs-type">int</span> n)</span></span>&#123;<br>    <span class="hljs-type">long</span> <span class="hljs-type">long</span> s=<span class="hljs-number">0</span>,a=<span class="hljs-number">1</span>;<br>    <span class="hljs-keyword">while</span>(n)&#123;<br>   <span class="hljs-keyword">if</span>(n%<span class="hljs-number">2</span>==<span class="hljs-number">1</span>)s+=a;<br>        n/=<span class="hljs-number">2</span>;<br>       a*=<span class="hljs-number">10</span>;<br>    &#125;<br>    <span class="hljs-keyword">return</span> s;<br>&#125;<br></code></pre></td></tr></table></figure><h1 id="文件-IO"><a href="#文件-IO" class="headerlink" title="文件 IO"></a>文件 IO</h1><figure class="highlight julia"><table><tr><td class="gutter"><pre><span class="line">1</span><br><span class="line">2</span><br><span class="line">3</span><br><span class="line">4</span><br><span class="line">5</span><br></pre></td><td class="code"><pre><code class="hljs julia">freopen(<span class="hljs-string">&quot;xxx&quot;</span>, <span class="hljs-string">&quot;r&quot;</span>, <span class="hljs-literal">stdin</span>);<br>freopen(<span class="hljs-string">&quot;xxx&quot;</span>, <span class="hljs-string">&quot;w&quot;</span>, <span class="hljs-literal">stdout</span>);<br><br>fclose(<span class="hljs-literal">stdin</span>);<br>fclose(<span class="hljs-literal">stdout</span>);<br></code></pre></td></tr></table></figure><h1 id="栈"><a href="#栈" class="headerlink" title="栈"></a>栈</h1><figure class="highlight cpp"><table><tr><td class="gutter"><pre><span class="line">1</span><br><span class="line">2</span><br><span class="line">3</span><br><span class="line">4</span><br><span class="line">5</span><br><span class="line">6</span><br><span class="line">7</span><br><span class="line">8</span><br><span class="line">9</span><br><span class="line">10</span><br><span class="line">11</span><br><span class="line">12</span><br><span class="line">13</span><br><span class="line">14</span><br><span class="line">15</span><br><span class="line">16</span><br><span class="line">17</span><br><span class="line">18</span><br><span class="line">19</span><br><span class="line">20</span><br></pre></td><td class="code"><pre><code class="hljs cpp"><span class="hljs-comment">// 定义（先进后出）</span><br>stack&lt;<span class="hljs-type">int</span>&gt; st;  <span class="hljs-comment">// 基本写法</span><br>stack&lt;pair&lt;<span class="hljs-type">int</span>, <span class="hljs-type">int</span>&gt;&gt; st1;  <span class="hljs-comment">// 存 pair</span><br><span class="hljs-keyword">struct</span> <span class="hljs-title class_">Node</span> &#123;<br><span class="hljs-type">int</span> a;<br><span class="hljs-type">int</span> b;<br><span class="hljs-type">bool</span> f;<br>&#125;;<br>stack&lt;Node&gt; st2;  <span class="hljs-comment">// 存结构体</span><br><br><span class="hljs-comment">// 入栈</span><br>st.<span class="hljs-built_in">push</span>(<span class="hljs-number">1</span>);<br>st<span class="hljs-number">1.</span><span class="hljs-built_in">push</span>(&#123;<span class="hljs-number">2</span>, <span class="hljs-number">3</span>&#125;);<br>st<span class="hljs-number">2.</span><span class="hljs-built_in">push</span>(&#123;<span class="hljs-number">4</span>, <span class="hljs-number">5</span>, <span class="hljs-literal">true</span>&#125;);<br><br><span class="hljs-comment">// 访问（只能访问栈顶）</span><br><span class="hljs-type">int</span> top = st.<span class="hljs-built_in">top</span>();  <span class="hljs-comment">// 取栈顶</span><br><span class="hljs-type">int</span> top1 = st<span class="hljs-number">1.</span><span class="hljs-built_in">top</span>().first;  <span class="hljs-comment">// 取 pair 第一项</span><br><span class="hljs-type">int</span> top1_2 = st<span class="hljs-number">1.</span><span class="hljs-built_in">top</span>().second;  <span class="hljs-comment">// 取 pair 第二项</span><br><span class="hljs-type">int</span> top2 = st<span class="hljs-number">2.</span><span class="hljs-built_in">top</span>().a;  <span class="hljs-comment">// 取结构体</span><br></code></pre></td></tr></table></figure><h1 id="树"><a href="#树" class="headerlink" title="树"></a>树</h1><h2 id="无向树"><a href="#无向树" class="headerlink" title="无向树"></a>无向树</h2><figure class="highlight cpp"><table><tr><td class="gutter"><pre><span class="line">1</span><br><span class="line">2</span><br><span class="line">3</span><br><span class="line">4</span><br><span class="line">5</span><br><span class="line">6</span><br><span class="line">7</span><br><span class="line">8</span><br><span class="line">9</span><br><span class="line">10</span><br><span class="line">11</span><br><span class="line">12</span><br><span class="line">13</span><br><span class="line">14</span><br><span class="line">15</span><br><span class="line">16</span><br><span class="line">17</span><br></pre></td><td class="code"><pre><code class="hljs cpp"><span class="hljs-comment">// 定义（邻接表）</span><br>vector&lt;<span class="hljs-type">int</span>&gt; tr[<span class="hljs-number">10005</span>];<br><br><span class="hljs-comment">// 读入</span><br><span class="hljs-type">int</span> n;<br>cin &gt;&gt; n;<br><span class="hljs-keyword">for</span>(<span class="hljs-type">int</span> i = <span class="hljs-number">0</span>; i &lt; n<span class="hljs-number">-1</span>; i++)&#123;<br><span class="hljs-type">int</span> u,v;<br>cin &gt;&gt; u &gt;&gt; v;<br>tr[u].<span class="hljs-built_in">push_back</span>(v);<br>tr[v].<span class="hljs-built_in">push_back</span>(u);<br>&#125;<br><br><span class="hljs-comment">// 遍历（成为有根树）</span><br><span class="hljs-function"><span class="hljs-type">void</span> <span class="hljs-title">dfs</span><span class="hljs-params">(<span class="hljs-type">int</span> u, <span class="hljs-type">int</span> fa)</span> </span>&#123;<br><br>&#125;<br></code></pre></td></tr></table></figure>]]></content>
    
    
